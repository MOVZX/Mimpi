# ══════════════════════════════════════════
# Mimpi Dashboard — Environment Variables
# ══════════════════════════════════════════
# Copy this file to .env and adjust values:
#   cp .env.example .env

# ── ComfyUI Server ──
# URL of your ComfyUI instance
COMFY_URI=http://COMFYUI_URL

# Auth token for ComfyUI (if required)
COMFY_TOKEN=

# ── Server Bind ──
# Host and port for the Mimpi dashboard server
HOST=0.0.0.0
PORT=8001

# ── MariaDB ──
DB_HOST=localhost
DB_PORT=3306
DB_NAME=database
DB_USER=user
DB_PASSWORD=password

# SeaweedFS
S3_ENDPOINT=http://S3_URL
S3_ACCESS_KEY=access
S3_SECRET_KEY=secret
S3_BUCKET=mimpi
